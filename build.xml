<project name="webapp" default="compile">

    <target name="clean">
        <delete dir="build"/>
    </target>

    <target name="compile">
        <mkdir dir="build"/>
        <echo message="Build Successful"/>
    </target>

    <target name="checkstyle">
        <echo message="Checkstyle target executed"/>
    </target>
<target name="Junit">
    <junit printsummary="yes">
        <classpath>
            <pathelement path="lib/junit-4.13.2.jar"/>
            <pathelement path="lib/hamcrest-core-1.3.jar"/>
            <pathelement path="build/classes"/>
        </classpath>
<batchtest>
    <fileset dir="src/test/java">
        <include name="**/*Test.java"/>
    </fileset>
</batchtest>
    </junit>
</target>
</project>